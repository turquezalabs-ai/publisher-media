# ===========================================
# Lottong Pinoy — Banner Creator Studio
# Environment Variables
# ===========================================

# DATA SOURCE (server-side only — used by /api/results route)
# Set this to your Hostinger URL to fetch results.json from there.
# If empty, the API serves the local public/results.json file.
DATA_SOURCE_URL=https://lottong-pinoy.com/results.json

# CORS — comma-separated domains allowed to fetch from the API
# Leave empty to allow all origins (default)
ALLOWED_ORIGINS=

# ===========================================
# META (FACEBOOK + INSTAGRAM) API
# ===========================================
# Get these from Meta for Developers (developers.facebook.com)
# The page access token must have pages_read_engagement and pages_manage_posts permissions.
# For Instagram, the Facebook Page must be linked to the Instagram Business Account.
META_ACCESS_TOKEN=your_long_lived_page_access_token
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret

# ===========================================
# TWITTER / X API
# ===========================================
# Get these from the Twitter Developer Portal (developer.x.com)
# OAuth 1.0a credentials with read and write permissions.
# The access token must have "tweet" and "media.upload" permissions.
TWITTER_API_KEY=your_api_key
TWITTER_API_SECRET=your_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret
